{
  "name": "wonwon-designs",
  "version": "1.0.0",
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write --log-level warn .",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:dev": "vitest run --watch --coverage",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsdown/css": "^0.22.4",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.4",
    "turbo": "^2.10.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": "prettier --check",
    "*.{ts,tsx,js,jsx}": [
      "prettier --check",
      "eslint"
    ]
  }
}
